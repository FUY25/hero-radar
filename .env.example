# Copy this file to `.env` and fill values locally.
# `.env` is ignored by git.

GITHUB_TOKEN=
PRODUCTHUNT_TOKEN=
PRODUCTHUNT_USER_CONTEXT=
APIFY_TOKEN=

# Optional X cookies for Apify following-list actors.
# Prefer a secondary X account if possible. These are session cookies.
X_AUTH_TOKEN=
X_CT0=

# Keep Apify dry by default. Set to true only after choosing actors and budget.
APIFY_ENABLE_RUNS=false
